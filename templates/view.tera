{% import "macros/_nav.tera" as nav %}
{% extends "_base.tera" %}
{% block title %}{{ page_title }} - {{ site_title }}{% endblock title %}
{% block body %}
{{ nav::page_header(title=page_title, current=slug, show_edit=true) }}
<section class="section">
  <div class="container is-max-desktop">
    <div class="content is-medium">{{ content | safe }}</div>
    <hr />
    {{ nav::back_link() }}
  </div>
</section>
{% endblock body %}
